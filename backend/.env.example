# =============================================================================
# BACKEND — Local development & deployment (Render)
# =============================================================================
# Copy to .env for local dev. Never commit .env.
# For Render: set these in Dashboard → Service → Environment (see ENV_SETUP.md).

# -----------------------------------------------------------------------------
# DATABASE (required)
# -----------------------------------------------------------------------------
# Option A — Direct async URL (Neon or any Postgres)
# RUNSQL_URL=postgresql+asyncpg://user:password@host:port/database

# Option B — Render PostgreSQL (Render sets DATABASE_URL when you link the DB)
# DATABASE_URL=postgresql://user:password@host/database

# -----------------------------------------------------------------------------
# AI / Groq (required for translate)
# -----------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile
# AI_FALLBACK_ENABLED=false
# AI_FALLBACK_MODEL=llama-3.1-8b-instant

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# PORT=8000

# -----------------------------------------------------------------------------
# CORS (required in production — add your Vercel URL)
# -----------------------------------------------------------------------------
# CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# RATE_LIMIT_REQUESTS=10
# RATE_LIMIT_WINDOW_SECONDS=60
# QUERY_TIMEOUT=10.0
# SELECT_LIMIT=50
# AUTH_ENABLED=false
# API_KEYS=key1,key2
# ERROR_TRACKING_ENABLED=true
# ALERTING_ENABLED=true
# MAX_SCHEMA_SIZE=8000
