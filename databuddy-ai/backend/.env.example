# Database Connection (Neon PostgreSQL)
# Convert standard postgresql:// to postgresql+asyncpg:// for async operations
RUNSQL_URL=postgresql+asyncpg://user:password@host:port/database?sslmode=require

# Groq AI API Key
GROQ_API_KEY=your_groq_api_key_here

# Optional: Groq Model (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: AI Fallback Model (enable fallback if primary fails)
AI_FALLBACK_ENABLED=false
AI_FALLBACK_MODEL=llama-3.1-8b-instant

# Optional: Schema Optimization (max schema size in characters before summarization)
MAX_SCHEMA_SIZE=8000

# Optional: Error Tracking
ERROR_TRACKING_ENABLED=true

# Optional: Alerting
ALERTING_ENABLED=true
ALERT_ERROR_THRESHOLD=10
ALERT_SLOW_QUERY_MS=5000
ALERT_COOLDOWN_SECONDS=300

# Optional: Query Timeout in seconds (default: 10.0)
QUERY_TIMEOUT=10.0

# Optional: SELECT Query Limit (default: 50 rows)
SELECT_LIMIT=50

# Optional: Rate Limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# Optional: CORS Configuration (comma-separated origins, default: http://localhost:3000)
CORS_ORIGINS=http://localhost:3000

# Optional: API Authentication
# Set AUTH_ENABLED=true to enable API key authentication
AUTH_ENABLED=false
# Comma-separated list of valid API keys
API_KEYS=your-api-key-1,your-api-key-2

# Optional: Server Port (default: 8000)
PORT=8000
