# =============================================================================
# DATABUDDY AI - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env in the respective directories and fill in your values
# Never commit .env files to version control!

# =============================================================================
# BACKEND ENVIRONMENT VARIABLES (.env in backend/ directory)
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE CONNECTION (REQUIRED)
# -----------------------------------------------------------------------------
# Neon PostgreSQL connection string (must use asyncpg driver)
# Format: postgresql+asyncpg://user:password@host:port/database
# Remove ?sslmode=require from URL - SSL is configured via connect_args
RUNSQL_URL=postgresql+asyncpg://user:password@ep-example.region.aws.neon.tech/database

# -----------------------------------------------------------------------------
# AI/LLM CONFIGURATION (REQUIRED)
# -----------------------------------------------------------------------------
# Groq API Key - Get yours from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Optional: Groq Model (default: llama-3.3-70b-versatile)
# Available models: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: AI Fallback Configuration
AI_FALLBACK_ENABLED=false
AI_FALLBACK_MODEL=llama-3.1-8b-instant

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------
# Server Port (default: 8000)
# Render/Vercel will override this with $PORT environment variable
PORT=8000

# -----------------------------------------------------------------------------
# CORS CONFIGURATION (REQUIRED FOR PRODUCTION)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
# For local development: http://localhost:3000
# For production: https://your-frontend-domain.vercel.app
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.vercel.app

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
# Maximum requests per window (default: 10)
RATE_LIMIT_REQUESTS=10

# Rate limit window in seconds (default: 60)
RATE_LIMIT_WINDOW_SECONDS=60

# -----------------------------------------------------------------------------
# QUERY CONFIGURATION
# -----------------------------------------------------------------------------
# Query timeout in seconds (default: 10.0)
QUERY_TIMEOUT=10.0

# SELECT query limit for safety (default: 50 rows)
SELECT_LIMIT=50

# -----------------------------------------------------------------------------
# AUTHENTICATION (OPTIONAL)
# -----------------------------------------------------------------------------
# Enable API key authentication
AUTH_ENABLED=false

# Comma-separated list of valid API keys
# Only used if AUTH_ENABLED=true
API_KEYS=your-api-key-1,your-api-key-2

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
# Enable AI features (default: true)
AI_ENABLED=true

# Enable error tracking (default: true)
ERROR_TRACKING_ENABLED=true

# Enable alerting (default: true)
ALERTING_ENABLED=true

# Error threshold for alerts (default: 10)
ALERT_ERROR_THRESHOLD=10

# Slow query threshold in milliseconds (default: 5000)
ALERT_SLOW_QUERY_MS=5000

# Alert cooldown in seconds (default: 300)
ALERT_COOLDOWN_SECONDS=300

# -----------------------------------------------------------------------------
# SCHEMA OPTIMIZATION
# -----------------------------------------------------------------------------
# Maximum schema size in characters before summarization (default: 8000)
MAX_SCHEMA_SIZE=8000

# =============================================================================
# FRONTEND ENVIRONMENT VARIABLES (.env.local in frontend/ directory)
# =============================================================================

# -----------------------------------------------------------------------------
# API CONFIGURATION (REQUIRED)
# -----------------------------------------------------------------------------
# Backend API URL
# For local development: http://localhost:8000
# For production: https://your-backend-url.onrender.com
# Note: NEXT_PUBLIC_ prefix makes this available in the browser
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# DEPLOYMENT PLATFORM SPECIFIC NOTES
# =============================================================================

# -----------------------------------------------------------------------------
# VERCEL (Frontend)
# -----------------------------------------------------------------------------
# 1. Go to your Vercel project settings
# 2. Navigate to Environment Variables
# 3. Add: NEXT_PUBLIC_API_URL = https://your-backend-url.onrender.com
# 4. Redeploy your application

# -----------------------------------------------------------------------------
# RENDER (Backend)
# -----------------------------------------------------------------------------
# 1. Create a new Web Service on Render
# 2. Connect your GitHub repository
# 3. Set the following:
#    - Build Command: pip install -r requirements.txt
#    - Start Command: uvicorn main:app --host 0.0.0.0 --port $PORT
#    - Environment: Python 3
# 4. Add all backend environment variables from this template
# 5. Important: Set CORS_ORIGINS to your Vercel frontend URL

# -----------------------------------------------------------------------------
# ENVIRONMENT VARIABLE SETUP CHECKLIST
# -----------------------------------------------------------------------------
# Backend (.env):
#   [ ] RUNSQL_URL - Your Neon PostgreSQL connection string
#   [ ] GROQ_API_KEY - Your Groq API key
#   [ ] CORS_ORIGINS - Your frontend URL(s)
#   [ ] PORT - Server port (usually auto-set by platform)
#
# Frontend (.env.local):
#   [ ] NEXT_PUBLIC_API_URL - Your backend API URL

# =============================================================================
# SECURITY NOTES
# =============================================================================
# - Never commit .env files to version control
# - Use platform-specific secret management for production
# - Rotate API keys regularly
# - Use HTTPS in production
# - Enable authentication (AUTH_ENABLED=true) for production APIs
# - Restrict CORS_ORIGINS to your actual frontend domains
